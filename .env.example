# Copy this file to .env for local reference (never commit .env)
# On Railway, set these in: Dashboard → Your Service → Variables

# Required
CLAUDE_API_KEY=sk-ant-api03-...
PEXELS_API_KEY=your_pexels_key_here
CRON_TOKEN=74f6eb802bb190b5141413cf3a2f9e84
ADMIN_PASSWORD_HASH=$2y$10$...  # generate: php -r "echo password_hash('pass', PASSWORD_BCRYPT);"
BLOG_URL=https://yourapp.railway.app

# SQLite on Railway persistent volume (mount volume to /app/data in Railway dashboard)
DB_PATH=/app/data/blog.db
LOG_PATH=/app/data/generate.log

# Set to 'false' for production (daily posts), leave unset for test mode (every 5 min)
TEST_MODE=false
